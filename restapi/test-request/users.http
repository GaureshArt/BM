@baseUrl = http://localhost:3000/api/v1

### ==========================================
### SUCCESS SCENARIOS (Run these first to populate data)
### ==========================================

### CREATE USER (Valid)
POST {{baseUrl}}/users
Content-Type: application/json

{
  "firstName": "Gauresh",
  "lastName": "Tambe",
  "email": "gauresh@example.com",
  "phoneNumber": "+919876543210",
  "password": "securePassword123",
  "role":"staff"
}

###

PATCH {{baseUrl}}/users/1
user-id:1
Content-Type: application/json

{
  "firstName":"Rahul"
}

### ==========================================
### ASSIGNMENT ERROR SCENARIOS
### ==========================================

### 1. USER_ALREADY_EXISTS (Create account with existing email)
# Run this right after the valid create above
POST {{baseUrl}}/users
Content-Type: application/json

{
  "firstName": "Gauresh Clone",
  "lastName": "Tambe",
  "email": "gauresh@example.com", 
  "phoneNumber": "+919876543210",
  "password": "securePassword123"
}


### 2. VALIDATION_ERROR / MALFORMED JSON
# Missing required fields or wrong types (Triggers ValidationPipe)
POST {{baseUrl}}/users
Content-Type: application/json

{
  "firstName": "raj",
  "email": "not-a-valid-email",
  "phoneNumber": 12345 
}


### 3. GATEWAY_TIMEOUT (Database connection times out)
# Triggers the async timeout() method in your service
GET {{baseUrl}}/users/timeout


### 4. INSUFFICIENT_PERMISSIONS (Delete another user's resource)
# Note: You need auth guards implemented for this to throw 403, 
# but this represents the assignment requirement.
DELETE {{baseUrl}}/users/1



# ### 5. RATE_LIMIT_EXCEEDED (Too many requests)
# # Spam this request 10+ times quickly to trigger ThrottlerGuard (if implemented)
# GET {{baseUrl}}/users


### 6. MISSING_AUTHENTICATION (Required auth token missing)
# Requesting a secure endpoint with no headers
GET {{baseUrl}}/users/secure-data
auth-key:my-secret-key
role:admin


### 7. INVALID_PAGINATION_OFFSET (Offset exceeds total records)
# Requesting page 100 when you only have 1 or 2 users
GET {{baseUrl}}/users?page=100&limit=10


### ==========================================
### EXTRA SERVICE & DTO VALIDATION TESTS
### ==========================================

### 8. VALIDATION_ERROR (Negative Pagination via DTO)
# Triggers your ListUsersDto class-validator rules (@Min(1))
GET {{baseUrl}}/users?page=-1&limit=-5


### 9. INVALID_FILTER_FIELD (Custom Service Error)
# Trying to filter by a field that doesn't exist in the User entity
GET {{baseUrl}}/users?filterField=hackerField&filterValue=123


### 10. INVALID_SORT_FIELD (Custom Service Error)
# Trying to sort by a field that doesn't exist
GET {{baseUrl}}/users?sortBy=nonExistentField&order=ASC


### 11. RESOURCE_NOT_FOUND (Updating a non-existent user)
PATCH {{baseUrl}}/users/9999
Content-Type: application/json

{
  "firstName": "Ghost"
}


### 12. RESOURCE_NOT_FOUND (Deleting a non-existent user)
DELETE {{baseUrl}}/users/9999